# WVNews Platform Environment Variables
# Copy this to .env.local and fill in your values

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/wvnews

# Authentication
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Stripe (Payments & Subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google (OAuth, Drive, Docs, Analytics)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Constant Contact (Newsletters)
CONSTANT_CONTACT_API_KEY=
CONSTANT_CONTACT_ACCESS_TOKEN=

# AI Services (OpenAI or Google Vertex)
OPENAI_API_KEY=sk-...
# OR
GOOGLE_VERTEX_PROJECT_ID=
GOOGLE_VERTEX_LOCATION=us-central1

# Cloud Storage (AWS S3 or GCS)
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=wvnews-assets
# OR
GCS_BUCKET=wvnews-assets
GCS_PROJECT_ID=

# Social Media APIs
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TWITTER_API_KEY=
TWITTER_API_SECRET=
INSTAGRAM_ACCESS_TOKEN=

# Email (SendGrid)
SENDGRID_API_KEY=

# Site Configuration
SITE_NAME=WVNews
SITE_URL=https://wvnews.com
